{
    "name": "iobroker.maxxi-charge",
    "version": "2.0.0-alpha.12",
    "description": "Adapter for integration and control of MaxxiCharge CCU devices, including data retrieval, configuration, and dynamic command sending.",
    "author": {
        "name": "Christoph B\\u00f6hrs",
        "email": "git@mr-bond.de"
    },
    "homepage": "https://github.com/blabond/ioBroker.maxxi-charge",
    "keywords": [
        "maxxisun",
        "maxxicharge",
        "ioBroker"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/blabond/ioBroker.maxxi-charge"
    },
    "license": "MIT",
    "dependencies": {
        "@iobroker/adapter-core": "^3.3.2",
        "minimist": "^1.2.8",
        "node-schedule": "^2.1.1",
        "semver": "^7.7.3"
    },
    "devDependencies": {
        "@alcalzone/release-script": "^5.1.1",
        "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
        "@alcalzone/release-script-plugin-license": "^5.1.1",
        "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
        "@iobroker/adapter-dev": "^1.5.0",
        "@iobroker/eslint-config": "^2.2.0",
        "@iobroker/testing": "^5.2.2",
        "@types/node": "^25.6.0",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.1",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.2"
    },
    "overrides": {
        "axios": "1.15.0",
        "follow-redirects": "1.16.0",
        "protobufjs": "7.5.5"
    },
    "main": "build/main.js",
    "files": [
        "admin",
        "build",
        "io-package.json"
    ],
    "scripts": {
        "clean": "node ./scripts/clean.mjs",
        "build": "npm run clean && tsc -p tsconfig.build.json",
        "watch": "tsc -p tsconfig.build.json --watch",
        "test:js": "mocha --config test/mocharc.custom.json \"test/**/*.test.mjs\"",
        "test:package": "mocha test/package.mjs --exit",
        "test:integration": "npm run build && mocha test/integration.mjs --exit",
        "test": "npm run build && npm run test:js && npm run test:package",
        "check": "tsc --noEmit -p tsconfig.check.json",
        "release": "release-script",
        "lint": "eslint -c eslint.config.mjs .",
        "lint:fix": "eslint -c eslint.config.mjs . --fix",
        "prepublishOnly": "npm run build && npm run check && npm run lint && npm test"
    },
    "engines": {
        "node": ">=22"
    },
    "bugs": {
        "url": "https://github.com/blabond/ioBroker.maxxi-charge/issues"
    },
    "readmeFilename": "README.md"
}
