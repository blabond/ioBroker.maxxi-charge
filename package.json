{
    "name": "iobroker.maxxi-charge",
    "version": "2.0.0-alpha.14",
    "description": "Adapter for integration and control of MaxxiCharge CCU devices, including data retrieval, configuration, and dynamic command sending.",
    "author": {
        "name": "Christoph B\\u00f6hrs",
        "email": "git@mr-bond.de"
    },
    "homepage": "https://github.com/blabond/ioBroker.maxxi-charge",
    "keywords": [
        "maxxisun",
        "maxxicharge",
        "ioBroker"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/blabond/ioBroker.maxxi-charge"
    },
    "license": "MIT",
    "dependencies": {
        "@iobroker/adapter-core": "^3.4.1",
        "node-schedule": "^2.1.1"
    },
    "devDependencies": {
        "@alcalzone/release-script": "^5.2.1",
        "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
        "@alcalzone/release-script-plugin-license": "^5.2.0",
        "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
        "@iobroker/adapter-dev": "^1.5.0",
        "@iobroker/eslint-config": "^2.3.4",
        "@iobroker/testing": "^5.2.2",
        "@tsconfig/node22": "^22.0.5",
        "@types/node": "^22",
        "typescript": "^6.0.3"
    },
    "overrides": {
        "axios": "1.16.1",
        "follow-redirects": "1.16.0",
        "protobufjs": "7.6.2"
    },
    "main": "build/main.js",
    "files": [
        "admin",
        "build",
        "io-package.json"
    ],
    "scripts": {
        "clean": "node ./scripts/clean.mjs",
        "build": "npm run clean && tsc -p tsconfig.build.json",
        "watch": "tsc -p tsconfig.build.json --watch",
        "test:js": "mocha --config test/mocharc.custom.json \"test/**/*.test.mjs\"",
        "test:package": "mocha test/package.mjs --exit",
        "test:integration": "npm run build && mocha test/integration.mjs --exit",
        "test": "npm run build && npm run test:js && npm run test:package",
        "check": "tsc --noEmit -p tsconfig.check.json",
        "release": "release-script",
        "release:verify-tag": "node ./scripts/ensure-release-tag.mjs",
        "lint": "eslint -c eslint.config.mjs .",
        "lint:fix": "eslint -c eslint.config.mjs . --fix",
        "format": "prettier \"{admin,docs,scripts,src,test}/**/*.{json,js,mjs,ts,md}\" \"*.{json,md,mjs}\" --write",
        "format:check": "prettier \"{admin,docs,scripts,src,test}/**/*.{json,js,mjs,ts,md}\" \"*.{json,md,mjs}\" --check",
        "prepublishOnly": "npm run release:verify-tag && npm run build && npm run check && npm run lint && npm test"
    },
    "engines": {
        "node": ">=22"
    },
    "bugs": {
        "url": "https://github.com/blabond/ioBroker.maxxi-charge/issues"
    },
    "readmeFilename": "README.md"
}
